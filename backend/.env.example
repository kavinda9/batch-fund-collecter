# Server
PORT=5001
NODE_ENV=development

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_service_account_email
FIREBASE_PRIVATE_KEY="your_private_key"

# CORS / Client Configuration
# On Localhost: set to http://localhost:5173
# On Vercel: set to your deployed Frontend URL (e.g., https://batch-fund-frontend.vercel.app)
CLIENT_URL=http://localhost:5173

# Firebase Web API Key (required for password verification REST API on backend)
FIREBASE_WEB_API_KEY=your_firebase_web_api_key

# Firebase Cloud Storage Bucket
FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
